# Copia este archivo a .env.local y rellena los valores.

# Clave de Google Gemini (gratis en https://aistudio.google.com/apikey).
# La usa el Coach (app/api/coach) para embeddings + generación. Servidor, NO expuesta.
GEMINI_API_KEY=

# (Opcional) Endpoint para el form de newsletter (POST { email }).
# Si la dejas vacía, el form abre el cliente de correo (mailto).
NEXT_PUBLIC_NEWSLETTER_ENDPOINT=
